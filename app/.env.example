# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Model configuration for UMMISCO Portal
# ─────────────────────────────────────────────────────────────────────────────

# ── APPLICATION ──────────────────────────────────────────────────────────────
APP_NAME="Portail UMMISCO"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080
APP_LOCALE=fr
APP_FALLBACK_LOCALE=en
APP_TIMEZONE=Africa/Dakar

# ── BASE DE DONNÉES — PostgreSQL 16 ───────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=ummisco_app
DB_USERNAME=ummisco_user
DB_PASSWORD=

# ── REDIS 7 ──────────────────────────────────────────────────────────────────
REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_SESSION_DB=2
REDIS_QUEUE_DB=3

# ── CACHE & SESSIONS ──────────────────────────────────────────────────────────
CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax

# ── QUEUES ────────────────────────────────────────────────────────────────────
QUEUE_CONNECTION=redis

# ── KEYCLOAK OIDC AUTHENTICATION ──────────────────────────────────────────────
KEYCLOAK_BASE_URL=http://keycloak:8080
KEYCLOAK_REALM=ummisco
KEYCLOAK_CLIENT_ID=laravel-app
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_REDIRECT_URI=http://localhost:8080/auth/callback
KEYCLOAK_MOCK=true

# ── MINIO S3 OBJECT STORAGE ───────────────────────────────────────────────────
FILESYSTEM_DISK=minio
MINIO_ENDPOINT=http://minio:9000
MINIO_KEY=
MINIO_SECRET=
MINIO_REGION=us-east-1
MINIO_BUCKET_PUBLIC=ummisco-public
MINIO_BUCKET_DATASETS=datasets
MINIO_BUCKET_MEDIAS=medias
MINIO_USE_PATH_STYLE=true
MINIO_PRESIGNED_TTL=3600

# ── OLLAMA LOCAL LLM ──────────────────────────────────────────────────────────
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=llama3
OLLAMA_TIMEOUT=60
OLLAMA_MAX_TOKENS=2048
OLLAMA_ENABLED=false

# ── MAIL ──────────────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ── LOGGING ───────────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_LEVEL=debug

# ── TELESCOPE ─────────────────────────────────────────────────────────────────
TELESCOPE_ENABLED=false
