# Fichiers d'environnement et secrets
app/.env
app/.env.*
!app/.env.example
*.key
*.pem

# Dépendances (bibliothèques)
app/vendor/
app/node_modules/

# Fichiers compilés par le Frontend (Vite)
app/public/build/
app/public/hot

# Caches et logs de l'application Laravel
app/storage/logs/*.log
app/storage/framework/cache/data/*
app/storage/framework/sessions/*
app/storage/framework/views/*
app/storage/app/public/*
app/bootstrap/cache/*.php

# Fichiers Système et configuration IDE
.idea/
.vscode/
.DS_Store
Thumbs.db
*.log
KEYCLOAK_PROD.md
RAILWAY_ENV.txt
MINIO_RAILWAY.md

# Dossier Fonctionnalités clé — garder uniquement les images
Fonctionnalités clé/*.doc
Fonctionnalités clé/*.xls
Fonctionnalités clé/*.html
Fonctionnalités clé/~$*
Fonctionnalités clé/*_fichiers/filelist.xml
Fonctionnalités clé/*_fichiers/colorschememapping.xml
Fonctionnalités clé/*_fichiers/themedata.thmx
Fonctionnalités clé/*_fichiers/stylesheet.css
Fonctionnalités clé/*_fichiers/tabstrip.html
Fonctionnalités clé/*_fichiers/header.html
Fonctionnalités clé/*_fichiers/sheet*.html

